# EditorConfig — https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

[*.kt]
# ktlint rule configuration
# no-wildcard-imports: disabled for existing codebase — tracked for cleanup in a future PR
ktlint_standard_no-wildcard-imports = disabled

[*.kts]
# Gradle scripts use snake_case for version variables — disable naming rule
ktlint_standard_property-naming = disabled
