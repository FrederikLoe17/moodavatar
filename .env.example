# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=moodavatar
POSTGRES_PASSWORD=changeme

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret
