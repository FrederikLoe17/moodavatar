# Copy this file to .env and fill in the values
# cp .env.example .env

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=moodavatar
POSTGRES_PASSWORD=changeme

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret
JWT_ISSUER=moodavatar
JWT_AUDIENCE=moodavatar-users
JWT_ACCESS_EXPIRY_MS=900000
JWT_REFRESH_EXPIRY_MS=2592000000

# ── App ───────────────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:5173
ALLOWED_ORIGIN=http://localhost:5173

# ── Frontend (Vite env vars — set in Vercel dashboard for production) ─────────
# Leave empty for local dev (Vite proxy handles it)
# VITE_API_BASE_URL=https://your-app.koyeb.app
