{
  "info": {
    "name": "MoodAvatar API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "auth_url",    "value": "http://localhost:8081" },
    { "key": "user_url",   "value": "http://localhost:8082" },
    { "key": "access_token", "value": "" },
    { "key": "user_id",    "value": "" },
    { "key": "refresh_token", "value": "" }
  ],
  "item": [
    {
      "name": "🔐 Auth Service",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.id) pm.collectionVariables.set('user_id', res.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{auth_url}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@test.de\",\n  \"username\": \"testuser\",\n  \"password\": \"Secret123\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.accessToken)  pm.collectionVariables.set('access_token',  res.accessToken);",
                  "if (res.refreshToken) pm.collectionVariables.set('refresh_token', res.refreshToken);",
                  "if (res.user?.id)     pm.collectionVariables.set('user_id',       res.user.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{auth_url}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@test.de\",\n  \"password\": \"Secret123\"\n}"
            }
          }
        },
        {
          "name": "Me (JWT)",
          "request": {
            "method": "GET",
            "url": "{{auth_url}}/auth/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.accessToken) pm.collectionVariables.set('access_token', res.accessToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{auth_url}}/auth/refresh",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refresh_token}}\"\n}"
            }
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "url": "{{auth_url}}/auth/forgot-password",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@test.de\"\n}"
            }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "url": "{{auth_url}}/auth/reset-password",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"<reset-token-aus-mailhog>\",\n  \"newPassword\": \"NewSecret123\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{auth_url}}/auth/logout",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refresh_token}}\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "👤 User Service",
      "item": [
        {
          "name": "Create Profile (intern)",
          "request": {
            "method": "POST",
            "url": "{{user_url}}/users/internal/profile",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"{{user_id}}\",\n  \"username\": \"testuser\",\n  \"displayName\": \"Test User\"\n}"
            }
          }
        },
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "url": "{{user_url}}/users/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        },
        {
          "name": "Update My Profile",
          "request": {
            "method": "PUT",
            "url": "{{user_url}}/users/me",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"displayName\": \"Mein neuer Name\",\n  \"bio\": \"Das bin ich!\"\n}"
            }
          }
        },
        {
          "name": "Search Users",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{user_url}}/users/search?q=test",
              "query": [{ "key": "q", "value": "test" }]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        },
        {
          "name": "Get Profile by ID",
          "request": {
            "method": "GET",
            "url": "{{user_url}}/users/{{user_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        }
      ]
    },
    {
      "name": "👥 Friends",
      "item": [
        {
          "name": "Get Friend List",
          "request": {
            "method": "GET",
            "url": "{{user_url}}/friends",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        },
        {
          "name": "Get Pending Requests",
          "request": {
            "method": "GET",
            "url": "{{user_url}}/friends/requests",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        },
        {
          "name": "Send Friend Request",
          "request": {
            "method": "POST",
            "url": "{{user_url}}/friends/requests/<receiverId>",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        },
        {
          "name": "Accept Friend Request",
          "request": {
            "method": "PATCH",
            "url": "{{user_url}}/friends/requests/<requestId>",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"ACCEPT\"\n}"
            }
          }
        },
        {
          "name": "Decline Friend Request",
          "request": {
            "method": "PATCH",
            "url": "{{user_url}}/friends/requests/<requestId>",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"DECLINE\"\n}"
            }
          }
        },
        {
          "name": "Remove Friend",
          "request": {
            "method": "DELETE",
            "url": "{{user_url}}/friends/<friendId>",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        }
      ]
    }
  ]
}
