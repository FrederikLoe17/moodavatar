{$DOMAIN} {
    # WebSocket — now served by monolith on port 8080
    handle /ws* {
        reverse_proxy backend:8080
    }

    # REST API — strip /api prefix before forwarding to monolith
    handle /api/* {
        uri strip_prefix /api
        reverse_proxy backend:8080
    }

    # Frontend SPA
    handle {
        reverse_proxy frontend:80
    }
}
